APP_NAME=
APP_ENV=
APP_DEBUG=
APP_KEY=

API_URL=

# Public status page URL template. `:slug` is replaced at runtime.
# Dev (path-based):   https://dev.uptizm.com/status/:slug
# Prod (subdomain):   https://:slug.uptizm.com
PUBLIC_STATUS_URL_TEMPLATE=https://:slug.uptizm.com

# Sentry
SENTRY_DSN=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0
SENTRY_REPLAY_SESSION_RATE=0.1
SENTRY_REPLAY_ERROR_RATE=1.0
